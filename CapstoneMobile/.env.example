# Copy to CapstoneMobile/.env (same folder as app.json). Do not commit .env.
# Use the SAME Supabase project as BRIDGESOFHOPE (web): Dashboard -> Settings -> API.
# Web uses VITE_*; Expo requires EXPO_PUBLIC_* so Metro can inline them.
#
# After saving, restart the bundler: npx expo start -c
#
# Optional: from CapstoneMobile run  npm run sync-env  to copy URL/key from ../BRIDGESOFHOPE/.env

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
