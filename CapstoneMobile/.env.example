# Copy to .env in THIS folder (next to app.json). Expo only reads EXPO_PUBLIC_* here — not VITE_*.
# Values: Supabase → Project Settings → API. After editing: npx expo start -c
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google sign-in: add every redirect URL Expo prints for auth (e.g. capstonemobile://auth/callback
# and exp://…/--/auth/callback in dev) under Supabase → Authentication → URL Configuration → Redirect URLs.
