# Copy to .env in BRIDGESOFHOPE/ before running the app.
# Do not commit .env.

# Required: Supabase values (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Expo mobile (CapstoneMobile): use the SAME URL and anon key. Either copy into
# CapstoneMobile/.env as EXPO_PUBLIC_SUPABASE_URL / EXPO_PUBLIC_SUPABASE_ANON_KEY
# (see CapstoneMobile/.env.example), or from CapstoneMobile run: npm run sync-env

# Staff login email: lastname + first initial @ role-based host — nurse.<root> or staff.<root>
# (e.g. decenad@nurse.bridgesofhope.ph). Root domain (no leading @):
# VITE_STAFF_EMAIL_ROOT_DOMAIN=bridgesofhope.ph
# Legacy: VITE_STAFF_INSTITUTIONAL_EMAIL_DOMAIN=staff.bridgesofhope.ph still works; root is taken as last two labels (bridgesofhope.ph).
# Shared initial password for every new staff (optional; must pass password policy). If unset, app uses a built-in default.
# VITE_STAFF_DEFAULT_INITIAL_PASSWORD=ChangeThis#YourOrg1

# Staff welcome email via Resend (Edge Function only — NOT read from this file in production):
# 1) https://resend.com — API key; verify bridgesofhope.ph (or use onboarding@resend.dev for limited tests).
# 2) npx supabase link --project-ref YOUR_REF
#    npx supabase secrets set RESEND_API_KEY=re_xxxxxxxx
#    Optional sender (pick one):
#    npx supabase secrets set RESEND_FROM_EMAIL=noreply@bridgesofhope.ph
#    npx supabase secrets set RESEND_FROM="Bridges of Hope <noreply@bridgesofhope.ph>"
#    Optional: HTTPS URL shown at top of welcome email (hosted logo on your site or CDN).
#    npx supabase secrets set RESEND_BRAND_LOGO_URL=https://your-domain.com/logo.png
#    npm run deploy:staff-welcome-email

# Google sign-in: Supabase Dashboard -> Authentication -> URL Configuration -> Redirect URLs
# must include this app's callback, e.g. http://localhost:5173/auth/callback and your production /auth/callback

# Optional — hospital referral scan (Groq API; browser exposes the key — use a backend proxy in production).
# VITE_GROQ_API_KEY=gsk_...
# VITE_GROQ_REFERRAL_SCAN_MODEL=llama-3.2-11b-vision-preview
# VITE_GROQ_REFERRAL_TEXT_MODEL=llama-3.3-70b-versatile
