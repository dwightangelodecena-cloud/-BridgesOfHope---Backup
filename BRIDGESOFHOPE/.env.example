# Copy to .env in this folder. Values: Supabase → Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google sign-in: Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
# must include this app’s callback, e.g. http://localhost:5173/auth/callback and your production /auth/callback

# Optional — Admin Patient Management → weekly report “AI” insights (browser exposes these; use a backend proxy in production)
# VITE_AI_WEEKLY_REPORT_PROVIDER=openai
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_WEEKLY_REPORT_MODEL=gpt-4o-mini
# VITE_ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_WEEKLY_REPORT_MODEL=claude-3-5-haiku-20241022
