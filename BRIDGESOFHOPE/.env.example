# Copy this file to .env in BRIDGESOFHOPE/ before running the app.
# Do not commit .env.

# Required: Supabase values (Project Settings -> API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google sign-in: Supabase Dashboard -> Authentication -> URL Configuration -> Redirect URLs
# must include this app's callback, e.g. http://localhost:5173/auth/callback and your production /auth/callback

# Optional — weekly report AI insights (browser exposes these; use a backend proxy in production).
# Choose one provider: groq | gemini | openai | anthropic
# If VITE_AI_WEEKLY_REPORT_PROVIDER is unset, the app auto-selects based on available keys.
# VITE_AI_WEEKLY_REPORT_PROVIDER=groq

# Groq (recommended for free usage)
# VITE_GROQ_API_KEY=
# VITE_GROQ_WEEKLY_REPORT_MODEL=llama-3.1-8b-instant

# Gemini
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_WEEKLY_REPORT_MODEL=gemini-2.0-flash

# OpenAI
# VITE_OPENAI_API_KEY=
# VITE_OPENAI_WEEKLY_REPORT_MODEL=gpt-4o-mini

# Anthropic
# VITE_ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_WEEKLY_REPORT_MODEL=claude-3-5-haiku-20241022